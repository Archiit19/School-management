    FE -- "login, roles, JWT" --> AUTH
    FE -- "user CRUD" --> USER
    FE --> SCHOOL
    FE --> ACAD
    FE --> STU
    FE --> ATT
    FE --> EXAM
    FE --> FIN

    AUTH -. profiles .-> USER
    AUTH -. memberships .-> SCHOOL
    USER -. credentials, roles .-> AUTH
    USER -. memberships .-> SCHOOL
    SCHOOL -. bootstrap roles .-> AUTH
    ACAD -. user lookup .-> USER
    STU -. pupil login .-> USER
    ATT -. user lookup .-> USER
    EXAM -. pupils .-> STU

    AUTH --> AUTHDB
    USER --> USERDB
    SCHOOL --> SCHOOLDB
    ACAD --> ACADDB
    STU --> STUDB
    ATT --> ATTDB
    EXAM --> EXAMDB
    FIN --> FINDB

